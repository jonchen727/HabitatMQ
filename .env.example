# ─── MQTT Broker ────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=enclosure

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3003

# ─── go2rtc (camera streaming) ──────────────────────────────────────────────
# Only needed if go2rtc runs on a different host or non-default port
# GO2RTC_HOST=localhost
# GO2RTC_PORT=1984

# ─── Data ───────────────────────────────────────────────────────────────────
# Directory for SQLite database (created automatically)
# DATA_DIR=./data
